#!/usr/bin/env bash

set -euo pipefail

build_dir="${1:?build directory is required}"
cache_dir="${2:?cache directory is required}"
env_dir="${3:?env directory is required}"
buildpack_dir="$(cd "$(dirname "$0")/.." && pwd)"

log() {
    echo "-----> $*"
}

load_env_dir() {
    if [[ ! -d "${env_dir}" ]]; then
        return 0
    fi

    while IFS= read -r -d '' env_file; do
        export "$(basename "${env_file}")=$(<"${env_file}")"
    done < <(find "${env_dir}" -maxdepth 1 -type f -print0)
}

normalize_index_name() {
    local raw_name="${1}"

    printf '%s' "${raw_name}" \
        | tr '[:lower:]' '[:upper:]' \
        | sed -E 's/[^A-Z0-9]+/_/g; s/^_+//; s/_+$//'
}

require_env() {
    local var_name="${1}"

    if [[ -z "${!var_name:-}" ]]; then
        log "Missing required config var: ${var_name}"
        exit 1
    fi
}

if [[ -n "${cache_dir}" ]]; then
    :
fi

load_env_dir

if [[ ! -f "${build_dir}/pyproject.toml" ]]; then
    log "Skipping: no pyproject.toml found in ${build_dir}"
    exit 0
fi

if ! grep -Eq '^\[\[tool\.uv\.index\]\]' "${build_dir}/pyproject.toml"; then
    log "Skipping: no uv named index found in pyproject.toml"
    exit 0
fi

if ! command -v aws >/dev/null 2>&1; then
    log "AWS CLI is required but was not found on PATH"
    exit 1
fi

require_env "AWS_CODEARTIFACT_DOMAIN"
require_env "AWS_CODEARTIFACT_DOMAIN_OWNER"
require_env "AWS_CODEARTIFACT_REGION"
require_env "AWS_CODEARTIFACT_REPOSITORY"

index_name="${UV_CODEARTIFACT_INDEX_NAME:-codeartifact}"
normalized_index_name="$(normalize_index_name "${index_name}")"

log "Fetching AWS CodeArtifact token for uv index ${index_name}"

token="$(
    aws codeartifact get-authorization-token \
        --domain "${AWS_CODEARTIFACT_DOMAIN}" \
        --domain-owner "${AWS_CODEARTIFACT_DOMAIN_OWNER}" \
        --region "${AWS_CODEARTIFACT_REGION}" \
        --query authorizationToken \
        --output text
)"

if [[ -z "${token}" || "${token}" == "None" ]]; then
    log "Failed to fetch a valid AWS CodeArtifact authorization token"
    exit 1
fi

export_script="${buildpack_dir}/export"

{
    printf '#!/usr/bin/env bash\n'
    printf 'export UV_INDEX_%s_USERNAME=%q\n' "${normalized_index_name}" "aws"
    printf 'export UV_INDEX_%s_PASSWORD=%q\n' "${normalized_index_name}" "${token}"
} > "${export_script}"

chmod +x "${export_script}"

log "Configured downstream uv authentication for index ${index_name}"

